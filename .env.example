# Copy this file to ".env" and fill in your key. (.env is git-ignored.)

# OpenAI — used by the app to generate content.
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# Max output tokens per request.
AI_MAX_TOKENS=8000

# Optional: change the port (default 3000)
# PORT=3000

# Optional: protect the site with a password (recommended when hosting publicly).
# When set, the browser asks for a login — enter any username and this password.
# APP_PASSWORD=choose-a-strong-password
